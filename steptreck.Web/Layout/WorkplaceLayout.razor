    private async Task LoadNotificationsAsync()
    {
        _notifications.Clear();
        var latest = await NotificationsVm.GetLatestAsync(20);
        _notifications.AddRange(latest);
        _unreadCount = await NotificationsVm.GetUnreadCountAsync();
    }

    private void OnNotifyReceived(steptreck.Domain.DTOs.NotificationDto dto)
    {
        _notifications.Insert(0, dto);
        _unreadCount++;
        AddToast(dto);
        JS.InvokeVoidAsync("steptreckNotifySound.play");
        InvokeAsync(StateHasChanged);
    }

    private async Task MarkReadAsync(steptreck.Domain.DTOs.NotificationDto dto)
    {
        if (!dto.IsRead)
        {
            var ok = await NotificationsVm.MarkReadAsync(dto.Id);
            if (ok)
            {
                dto.IsRead = true;
                if (_unreadCount > 0)
                    _unreadCount--;
            }
        }
    }

    private async Task ToggleNotifications()
    {
        _notificationsOpen = !_notificationsOpen;
        if (_notificationsOpen)
            await LoadNotificationsAsync();
    }

    private void CloseNotifications()
    {
        _notificationsOpen = false;
    }

    private void AddToast(steptreck.Domain.DTOs.NotificationDto dto)
    {
        var toast = new ToastItem
        {
            Id = Guid.NewGuid(),
            Text = dto.Text,
            CreatedAt = dto.CreatedAt == default ? DateTime.Now : dto.CreatedAt
        };

        _toasts.Insert(0, toast);
        _ = RemoveToastAsync(toast);
    }

    private async Task CheckStopwatchReminderAsync()
    {
        if (!_stopwatchRunning)
            return;

        var elapsedMinutes = (int)Math.Floor(_stopwatchElapsed.TotalMinutes);
        var reminderMinute = (elapsedMinutes / 45) * 45;
        if (reminderMinute < 45 || reminderMinute <= _lastStopwatchReminderMinute)
            return;

        _lastStopwatchReminderMinute = reminderMinute;

        var toast = new ToastItem
        {
            Id = Guid.NewGuid(),
            Title = "⏰ Напоминание",
            Text = $"Ты уже {reminderMinute} минут за работой 💻 — самое время немного размяться! Пара минут движения поможет снять напряжение и вернуться к работе с новыми силами ✨",
            LinkUrl = "/doc/wormap.pdf",
            LinkText = "Скачать 👍",
            CreatedAt = DateTime.Now
        };

        _toasts.Insert(0, toast);
        await JS.InvokeVoidAsync("steptreckNotifySound.play");
        _ = RemoveToastAsync(toast);
        await PersistStopwatchStateAsync();
    }

    private async Task RemoveToastAsync(ToastItem toast)
    {
        await Task.Delay(10000);
        if (toast.IsClosing)
            return;

        toast.IsClosing = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(600);
        _toasts.Remove(toast);
        await InvokeAsync(StateHasChanged);
    }

    private async Task DismissToastAsync(ToastItem toast)
    {
        if (toast.IsClosing)
            return;

        toast.IsClosing = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(220);
        _toasts.Remove(toast);
        await InvokeAsync(StateHasChanged);
    }

    private static string FormatDate(DateTime value)
