                return "active";
            if (section == "sessions-active" && path.Contains("sessions/active", StringComparison.OrdinalIgnoreCase))
                return "active";
            if (section == "sessions-history" && path.Contains("sessions/history", StringComparison.OrdinalIgnoreCase) &&
