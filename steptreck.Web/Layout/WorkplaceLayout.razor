    private string GetTeamNavClass(string section)
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        if (!path.StartsWith("workplace", StringComparison.OrdinalIgnoreCase))
            return "";

        var teamBase = _teamScopedProjectId.HasValue && _teamScopedTeamId.HasValue
            ? $"workplace/projects/{_teamScopedProjectId}/teams/{_teamScopedTeamId}"
            : string.Empty;

        if (string.IsNullOrWhiteSpace(teamBase))
            return "";

        if (section == "info" && string.Equals(path, teamBase, StringComparison.OrdinalIgnoreCase))
            return "active";
        if (section == "members" && path.Contains($"{teamBase}/members", StringComparison.OrdinalIgnoreCase))
            return "active";
        if (section == "stats" && path.Contains($"{teamBase}/stats", StringComparison.OrdinalIgnoreCase))
            return "active";
        if (section == "calendar" && path.Contains($"{teamBase}/calendar", StringComparison.OrdinalIgnoreCase))
            return "active";
        if (section == "files" && path.Contains($"{teamBase}/files", StringComparison.OrdinalIgnoreCase))
            return "active";
        if (section == "tasks" && path.Contains($"{teamBase}/tasks", StringComparison.OrdinalIgnoreCase))
            return "active";
        if (section == "chat" && path.Contains($"{teamBase}/chat", StringComparison.OrdinalIgnoreCase))
            return "active";
        if (section == "project-files" && _teamScopedProjectId.HasValue &&
            path.Contains($"workplace/projects/{_teamScopedProjectId}/files", StringComparison.OrdinalIgnoreCase))
            return "active";

        return "";
    }

