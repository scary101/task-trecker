    private static string ToFirstAndLastName(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0)
            return "StepTreck";
        if (parts.Length == 1)
            return parts[0];
        return $"{parts[0]} {parts[1]}";
    }

