@page "/reset-password/request"
@using steptreck.Domain.DTOs.AuthDTOs
@inject steptreck.Web.ViewModel.ResetPasswordViewModel Vm
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Восстановление пароля — StepTreck</PageTitle>

<main class="page reset-page">
    <section class="reset-card card">
        <div class="reset-head">
            <h1>Восстановление пароля</h1>
            <p>Укажи email, на который зарегистрирован аккаунт. Мы отправим ссылку для восстановления.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_alert))
        {
            <div class="alert @(_alertKind)">@_alert</div>
        }

        <EditForm Model="_email" OnValidSubmit="SendAsync">
            <DataAnnotationsValidator />
            <ValidationSummary class="vsummary" />
            <div class="form-grid">
                <div class="field span-2">
                    <label class="label">Email</label>
                    <InputText class="input" @bind-Value="_email.Email" placeholder="name@company.com" />
                </div>
            </div>
            <div class="actions">
                <button class="btn primary" type="submit" disabled="@(_busy || _cooldownRemaining > 0)">Отправить ссылку</button>
                <a class="btn ghost" href="/login">Войти</a>
            </div>
            @if (_cooldownRemaining > 0)
            {
                <div class="cooldown">Повторный запрос можно сделать через @_cooldownLabel</div>
            }
        </EditForm>
    </section>

    <aside class="reset-info card">
        <h2>Как это работает</h2>
        <ul class="info-list">
            <li>Мы отправим ссылку на почту, указанную при регистрации.</li>
            <li>Ссылка будет активна ограниченное время.</li>
            <li>Если письма нет — проверь папку «Спам».</li>
        </ul>
    </aside>
</main>

@code {
    private const string CooldownKey = "resetPwdCooldownUntil";
    private EmailDto _email = new() { Email = "" };
    private bool _busy;
    private string? _alert;
    private string _alertKind = "err";
    private int _cooldownRemaining;
    private System.Timers.Timer? _cooldownTimer;

    private string _cooldownLabel => TimeSpan.FromSeconds(_cooldownRemaining).ToString("mm\\:ss");

    protected override async Task OnInitializedAsync()
    {
        await LoadCooldownAsync();
    }

    private async Task LoadCooldownAsync()
    {
        try
        {
            var untilRaw = await JS.InvokeAsync<string>("localStorage.getItem", CooldownKey);
            if (long.TryParse(untilRaw, out var untilUnix))
            {
                var until = DateTimeOffset.FromUnixTimeSeconds(untilUnix);
                var remaining = (int)Math.Ceiling((until - DateTimeOffset.UtcNow).TotalSeconds);
                if (remaining > 0)
                {
                    StartCooldown(remaining, persist: false);
                    return;
                }
            }
            await JS.InvokeVoidAsync("localStorage.removeItem", CooldownKey);
        }
        catch
        {
        }
    }

    private async Task SendAsync()
    {
        if (_cooldownRemaining > 0)
            return;

        _alert = null;
        _alertKind = "err";
        _busy = true;

        try
        {
            var ok = await Vm.SendResetLinkAsync(_email);
            if (ok)
            {
                _alertKind = "ok";
                _alert = "Если пользователь существует, ссылка была отправлена.";
            }
            else
            {
                _alert = "Не удалось отправить ссылку. Попробуйте позже.";
            }
        }
        catch
        {
            _alert = "Ошибка сети или сервера.";
        }
        finally
        {
            _busy = false;
            await StartCooldownAsync(60);
        }
    }

    private async Task StartCooldownAsync(int seconds)
    {
        if (seconds <= 0)
            return;

        var until = DateTimeOffset.UtcNow.AddSeconds(seconds).ToUnixTimeSeconds();
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", CooldownKey, until.ToString());
        }
        catch
        {
        }

        StartCooldown(seconds, persist: false);
    }

    private void StartCooldown(int seconds, bool persist)
    {
        if (seconds <= 0)
            return;

        _cooldownRemaining = seconds;
        _cooldownTimer?.Stop();
        _cooldownTimer?.Dispose();
        _cooldownTimer = new System.Timers.Timer(1000);
        _cooldownTimer.Elapsed += async (_, __) =>
        {
            if (_cooldownRemaining <= 0)
            {
                _cooldownTimer?.Stop();
                return;
            }

            _cooldownRemaining--;
            if (_cooldownRemaining <= 0)
            {
                _cooldownRemaining = 0;
                _cooldownTimer?.Stop();
                try
                {
                    await JS.InvokeVoidAsync("localStorage.removeItem", CooldownKey);
                }
                catch
                {
                }
            }
            _ = InvokeAsync(StateHasChanged);
        };
        _cooldownTimer.AutoReset = true;
        _cooldownTimer.Start();
    }

    public void Dispose()
    {
        _cooldownTimer?.Stop();
        _cooldownTimer?.Dispose();
    }
}
