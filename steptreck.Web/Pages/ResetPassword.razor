@page "/reset-password"
@using steptreck.Domain.DTOs.AuthDTOs
@inject steptreck.Web.ViewModel.ResetPasswordViewModel Vm
@inject NavigationManager Nav

<PageTitle>Смена пароля — StepTreck</PageTitle>

<main class="page reset-page">
    <section class="reset-card card">
        <div class="reset-head">
            <h1>Смена пароля</h1>
            <p>Введите новый пароль. Ссылка действует ограниченное время.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_alert))
        {
            <div class="alert @(_alertKind)">@_alert</div>
        }

        @if (_tokenChecked && !_tokenValid)
        {
            <div class="token-error">
                Ссылка недействительна или истекла. Запросите новую.
                <a href="/reset-password/request">Запросить снова</a>
            </div>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="ResetAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="vsummary" />

                <div class="form-grid">
                    <div class="field">
                        <label class="label">Новый пароль</label>
                        <InputText class="input" type="password" @bind-Value="_model.Password" placeholder="••••••••" />
                    </div>
                    <div class="field">
                        <label class="label">Повторите пароль</label>
                        <InputText class="input" type="password" @bind-Value="_model.Reset" placeholder="••••••••" />
                    </div>
                </div>

                <div class="actions">
                    <button class="btn primary" type="submit" disabled="@(_busy || !_tokenValid)">
                        Сохранить пароль
                    </button>
                    <a class="btn ghost" href="/login">Войти</a>
                </div>
            </EditForm>
        }
    </section>

    <aside class="reset-info card">
        <h2>Советы по безопасности</h2>
        <ul class="info-list">
            <li>Используйте 8+ символов и разные регистры.</li>
            <li>Не используйте тот же пароль, что и в почте.</li>
            <li>Храните пароли в менеджере.</li>
        </ul>
    </aside>
</main>

@code {
    private ResetPasswordDto _model = new();
    private bool _busy;
    private string? _alert;
    private string _alertKind = "err";
    private bool _tokenChecked;
    private bool _tokenValid = true;

    protected override async Task OnInitializedAsync()
    {
        var token = GetQueryParam("token");
        if (string.IsNullOrWhiteSpace(token))
        {
            _tokenValid = false;
            _tokenChecked = true;
            _alertKind = "err";
            _alert = "Токен не найден в ссылке.";
            return;
        }

        _model.Token = token;

        try
        {
            _tokenValid = await Vm.CheckToken(token);
        }
        catch
        {
            _tokenValid = false;
        }
        finally
        {
            _tokenChecked = true;
        }
    }

    private async Task ResetAsync()
    {
        _alert = null;
        _alertKind = "err";

        _busy = true;
        try
        {
            var ok = await Vm.ResetPasswordAsync(_model);
            if (ok)
            {
                _alertKind = "ok";
                _alert = "Пароль успешно изменен. Теперь можно войти.";
            }
            else
            {
                _alert = "Не удалось изменить пароль.";
            }
        }
        catch
        {
            _alert = "Ошибка сети или сервера.";
        }
        finally
        {
            _busy = false;
        }
    }

    private string? GetQueryParam(string key)
    {
        var uri = new Uri(Nav.Uri);
        var query = uri.Query;
        if (string.IsNullOrWhiteSpace(query))
            return null;

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && string.Equals(kv[0], key, StringComparison.OrdinalIgnoreCase))
                return Uri.UnescapeDataString(kv[1]);
        }

        return null;
    }
}
