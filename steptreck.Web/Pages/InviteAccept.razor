@page "/invite/accept"
@using steptreck.Domain.DTOs.InviteDTO
@inject steptreck.Web.ViewModel.InviteViewModel InviteVm
@inject steptreck.Web.ViewModel.AuthViewModel AuthVm
@inject steptreck.Web.Services.IJwtService JwtService
@inject steptreck.Web.Services.IInviteTokenStore InviteTokenStore
@inject NavigationManager Nav

<PageTitle>Принять приглашение — StepTreck</PageTitle>

<main class="page invite-accept">
    <section class="invite-card card">
        <div class="invite-head">
            <h1>Принять приглашение</h1>
            <p>Сейчас попробуем принять приглашение. Ничего вводить не нужно.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_alert))
        {
            <div class="alert @(_alertKind)">
                @_alert
            </div>
        }

        <div class="actions">
            @if (_needsAuth)
            {
                <a class="btn primary" href="/register/user">Создать аккаунт</a>
                <a class="btn ghost" href="/login">Войти</a>
            }
            else
            {
                <a class="btn ghost" href="/">На главную</a>
                <a class="btn primary" href="/workplace">К рабочему месту</a>
            }
        </div>
    </section>
</main>

@code {
    private string? _alert;
    private string _alertKind = "ok";
    private bool _needsAuth;

    protected override async Task OnInitializedAsync()
    {
        var token = GetQueryParam("token");
        if (string.IsNullOrWhiteSpace(token))
        {
            token = await InviteTokenStore.GetTokenAsync();
        }

        if (string.IsNullOrWhiteSpace(token))
        {
            _alertKind = "err";
            _alert = "Токен приглашения не найден.";
            return;
        }

        var jwt = await JwtService.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(jwt))
        {
            await InviteTokenStore.SetTokenAsync(token);
            _needsAuth = true;
            _alertKind = "err";
            _alert = "Чтобы принять приглашение, сначала зарегистрируйтесь или войдите. После входа мы автоматически продолжим.";
            return;
        }

        var res = await InviteVm.AcceptInviteAsync(new AcceptInviteDto { Token = token });
        if (res.Success)
        {
            _alertKind = "ok";
            _alert = res.Message ?? "Приглашение принято.";
            await InviteTokenStore.ClearTokenAsync();
            Nav.NavigateTo("/workplace", forceLoad: true);
        }
        else
        {
            _alertKind = "err";
            _alert = res.Error ?? "Не удалось принять приглашение.";
        }
    }

    private string? GetQueryParam(string key)
    {
        var uri = new Uri(Nav.Uri);
        var query = uri.Query;
        if (string.IsNullOrWhiteSpace(query))
            return null;

        foreach (var part in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length == 2 && string.Equals(kv[0], key, StringComparison.OrdinalIgnoreCase))
                return Uri.UnescapeDataString(kv[1]);
        }

        return null;
    }
}
