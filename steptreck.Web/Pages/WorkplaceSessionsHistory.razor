@page "/workplace/sessions/history"
@layout steptreck.Web.Layout.WorkplaceLayout
@using System.Text
@using steptreck.Domain.DTOs.ProjectDTOs
@using steptreck.Domain.DTOs.TeamDTOs
@using steptreck.Domain.DTOs.WorkSessionDTOs
@using steptreck.Domain.Enums
@inject steptreck.Web.ViewModel.WorkSessionViewModel WorkSessionVm
@inject steptreck.Web.ViewModel.MembersVm MembersVm
@inject steptreck.Web.ViewModel.ProjectsViewModel ProjectsVm
@inject steptreck.Web.ViewModel.ProjectTeamsViewModel TeamsVm
@inject steptreck.Web.Services.IUserRoleStore RoleStore
@inject NavigationManager Nav
@inject IJSRuntime JS

<main class="page sessions-history-page">
    <section class="section">
        <div class="section-head">
            <div>
                <h1>История сессий</h1>
                <p class="section-subtitle">@_subtitle</p>
            </div>
            <button class="btn primary" type="button" @onclick="ReloadAsync" disabled="@_loading">Обновить</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_alert))
        {
            <div class="alert err">@_alert</div>
        }

        <div class="toolbar-head">
            <div class="history-summary">Найдено: @FilteredItems.Count · @_scopeLabel</div>
            <button class="filter-toggle" type="button" @onclick="ToggleFilters" aria-expanded="@(!_filtersCollapsed)">
                <i class="bi @(_filtersCollapsed ? "bi-chevron-down" : "bi-chevron-up")" aria-hidden="true"></i>
                <span>@(_filtersCollapsed ? "Показать фильтры" : "Скрыть фильтры")</span>
            </button>
        </div>

        @if (!_filtersCollapsed)
        {
            <section class="history-toolbar card @(_showOwnerFilters ? "has-owner-filters" : null)">
                <label class="history-filter search">
                    <span>Поиск</span>
                    <input @bind="_searchTerm" @bind:event="oninput" type="search" placeholder="" />
                </label>

                @if (_showOwnerFilters)
                {
                    <label class="history-filter">
                        <span>Проект</span>
                        <select value="@_selectedProjectId" @onchange="OnProjectFilterChanged">
                            <option value="">Все проекты</option>
                            @foreach (var project in _projects)
                            {
                                <option value="@project.Id">@project.Name</option>
                            }
                        </select>
                    </label>

                    <label class="history-filter">
                        <span>Команда</span>
                        <select value="@_selectedTeamId" @onchange="OnTeamFilterChanged" disabled="@(!_ownerTeams.Any())">
                            <option value="">@(_ownerTeams.Any() ? "Все команды проекта" : "Сначала выберите проект")</option>
                            @foreach (var team in _ownerTeams)
                            {
                                <option value="@team.Id">@team.Name</option>
                            }
                        </select>
                    </label>
                }

                <label class="history-filter">
                    <span>Дата от</span>
                    <input value="@_dateFrom" @onchange="OnDateFromChanged" type="date" />
                </label>

                <label class="history-filter">
                    <span>Дата до</span>
                    <input value="@_dateTo" @onchange="OnDateToChanged" type="date" />
                </label>

                <div class="history-filter history-filter-action">
                    <span>Выгрузка</span>
                    <button class="btn ghost export-btn" type="button" @onclick="ExportAsync" disabled="@(!FilteredItems.Any())">
                        <i class="bi bi-download" aria-hidden="true"></i>
                        <span>В Excel</span>
                    </button>
                </div>

                <div class="history-filter history-filter-action">
                    <span>Сброс</span>
                    <button class="btn ghost export-btn" type="button" @onclick="ResetFiltersAsync">
                        <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                        <span>Сбросить</span>
                    </button>
                </div>
            </section>
        }

        <section class="history-results">
            <section class="history-list">
                @if (_loading)
                {
                    <div class="history-empty card">Загружаем историю сессий...</div>
                }
                else if (FilteredItems.Count == 0)
                {
                    <div class="history-empty card">По выбранным фильтрам сессии не найдены.</div>
                }
                else
                {
                    @foreach (var item in FilteredItems)
                    {
                        <article class="history-card card">
                            <div class="history-main">
                                <div>
                                    <div class="history-title">@FormatUserShortName(item.UserName)</div>
                                    <div class="history-subtitle">Сессия #@item.SessionId, пользователь #@item.UserId</div>
                                </div>
                                <span class="history-status @GetStatusClass(item.Status)">@GetStatusLabel(item.Status)</span>
                            </div>
                            <div class="history-meta">
                                <div class="history-meta-item">
                                    <span>Старт</span>
                                    <strong>@FormatDate(item.StartedAtUtc)</strong>
                                </div>
                                <div class="history-meta-item">
                                    <span>Завершение</span>
                                    <strong>@FormatDate(item.EndedAtUtc)</strong>
                                </div>
                                <div class="history-meta-item">
                                    <span>Длительность</span>
                                    <strong>@FormatDuration(item.DurationSeconds)</strong>
                                </div>
                            </div>
                        </article>
                    }
                }
            </section>
        </section>
    </section>
</main>

@code {
    private const int OwnerRoleId = 1;
    private const int TeamLeadRoleId = 3;
    private const int EmployeeRoleId = 4;
    private const int AdminRoleId = 5;

    private readonly List<WorkSessionHistoryDto> _items = new();
    private List<ProjectReadDto> _projects = new();
    private List<TeamReadDto> _ownerTeams = new();
    private bool _loading = true;
    private bool _showOwnerFilters;
    private string? _alert;
    private string _searchTerm = string.Empty;
    private string? _dateFrom;
    private string? _dateTo;
    private string _selectedProjectId = string.Empty;
    private string _selectedTeamId = string.Empty;
    private bool _filtersCollapsed;
    private int? _teamScopeId;
    private string _subtitle = "Завершенные рабочие сессии по всей организации.";
    private string _scopeLabel = "вся организация";

    private List<WorkSessionHistoryDto> FilteredItems => _items
        .Where(MatchesSearch)
        .Where(MatchesDateFrom)
        .Where(MatchesDateTo)
        .OrderByDescending(x => x.StartedAtUtc)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!await InitializeScopeAsync())
            return;

        await LoadAsync();
    }

    private async Task<bool> InitializeScopeAsync()
    {
        var roleId = await RoleStore.GetRoleIdAsync();

        if (roleId == EmployeeRoleId)
        {
            var employeeProfile = await MembersVm.GetMyProfileAsync();
            if (employeeProfile?.Team is not null)
            {
                _teamScopeId = employeeProfile.Team.TeamId;
                _subtitle = "Завершенные рабочие сессии сотрудников вашей команды.";
                _scopeLabel = $"команда #{employeeProfile.Team.TeamId}";
                return true;
            }

            Nav.NavigateTo("/workplace", forceLoad: true);
            return false;
        }

        if (roleId == OwnerRoleId || roleId == AdminRoleId)
        {
            _projects = await ProjectsVm.GetAllAsync();
            _showOwnerFilters = true;
            _subtitle = "Завершенные рабочие сессии по всей организации.";
            _scopeLabel = "вся организация";
            return true;
        }

        var profile = await MembersVm.GetMyProfileAsync();
        if (profile?.Team is null)
        {
            Nav.NavigateTo("/workplace", forceLoad: true);
            return false;
        }

        if (roleId == TeamLeadRoleId)
        {
            _teamScopeId = profile.Team.TeamId;
            _subtitle = "Завершенные рабочие сессии сотрудников вашей команды.";
            _scopeLabel = $"команда #{profile.Team.TeamId}";
            return true;
        }

        _subtitle = "Завершенные рабочие сессии по всей организации.";
        _scopeLabel = "вся организация";
        return true;
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _alert = null;
        try
        {
            _items.Clear();
            _items.AddRange(await LoadItemsByScopeAsync());
        }
        catch (Exception ex)
        {
            _alert = ex.Message;
            _items.Clear();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<IReadOnlyList<WorkSessionHistoryDto>> LoadItemsByScopeAsync()
    {
        if (_teamScopeId.HasValue)
            return await WorkSessionVm.GetTeamCompletedSessionsAsync(_teamScopeId.Value);

        if (int.TryParse(_selectedTeamId, out var selectedTeamId))
            return await WorkSessionVm.GetTeamCompletedSessionsAsync(selectedTeamId);

        if (int.TryParse(_selectedProjectId, out var selectedProjectId))
            return await WorkSessionVm.GetProjectCompletedSessionsAsync(selectedProjectId);

        return await WorkSessionVm.GetCompletedSessionsAsync();
    }

    private async Task OnProjectFilterChanged(ChangeEventArgs args)
    {
        _selectedProjectId = args.Value?.ToString() ?? string.Empty;
        _selectedTeamId = string.Empty;
        _ownerTeams = [];
        _scopeLabel = "вся организация";

        if (int.TryParse(_selectedProjectId, out var selectedProjectId))
        {
            _ownerTeams = await TeamsVm.GetByProjectAsync(selectedProjectId);
            _scopeLabel = $"проект #{selectedProjectId}";
        }

        await LoadAsync();
    }

    private async Task OnTeamFilterChanged(ChangeEventArgs args)
    {
        _selectedTeamId = args.Value?.ToString() ?? string.Empty;
        if (int.TryParse(_selectedTeamId, out var selectedTeamId))
        {
            _scopeLabel = $"команда #{selectedTeamId}";
        }
        else if (int.TryParse(_selectedProjectId, out var selectedProjectId))
        {
            _scopeLabel = $"проект #{selectedProjectId}";
        }
        else
        {
            _scopeLabel = "вся организация";
        }

        await LoadAsync();
    }

    private void ToggleFilters()
    {
        _filtersCollapsed = !_filtersCollapsed;
    }

    private bool MatchesSearch(WorkSessionHistoryDto item)
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
            return true;

        var search = _searchTerm.Trim();
        return item.UserName.Contains(search, StringComparison.OrdinalIgnoreCase)
            || FormatUserShortName(item.UserName).Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesDateFrom(WorkSessionHistoryDto item)
    {
        if (!DateOnly.TryParse(_dateFrom, out var from))
            return true;

        return DateOnly.FromDateTime(item.StartedAtUtc.ToLocalTime()) >= from;
    }

    private bool MatchesDateTo(WorkSessionHistoryDto item)
    {
        if (!DateOnly.TryParse(_dateTo, out var to))
            return true;

        return DateOnly.FromDateTime(item.StartedAtUtc.ToLocalTime()) <= to;
    }

    private void OnDateFromChanged(ChangeEventArgs args)
    {
        _dateFrom = args.Value?.ToString();
    }

    private void OnDateToChanged(ChangeEventArgs args)
    {
        _dateTo = args.Value?.ToString();
    }

    private async Task ResetFiltersAsync()
    {
        var shouldReload = _showOwnerFilters && (!string.IsNullOrEmpty(_selectedProjectId) || !string.IsNullOrEmpty(_selectedTeamId));

        _searchTerm = string.Empty;
        _dateFrom = null;
        _dateTo = null;
        _selectedProjectId = string.Empty;
        _selectedTeamId = string.Empty;
        _ownerTeams = [];
        _scopeLabel = _teamScopeId.HasValue ? $"команда #{_teamScopeId.Value}" : "вся организация";

        if (shouldReload)
            await LoadAsync();
    }

    private async Task ExportAsync()
    {
        var rows = new StringBuilder();
        rows.AppendLine("\uFEFFПользователь,Статус,Старт,Завершение,Длительность");

        foreach (var item in FilteredItems)
        {
            rows.Append(EscapeCsv(FormatUserShortName(item.UserName))).Append(',')
                .Append(EscapeCsv(GetStatusLabel(item.Status))).Append(',')
                .Append(EscapeCsv(FormatDate(item.StartedAtUtc))).Append(',')
                .Append(EscapeCsv(FormatDate(item.EndedAtUtc))).Append(',')
                .Append(EscapeCsv(FormatDuration(item.DurationSeconds))).AppendLine();
        }

        var bytes = Encoding.UTF8.GetBytes(rows.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"sessions-history_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("steptreckDownload.saveFile", fileName, "text/csv;charset=utf-8", base64);
    }

    private static string EscapeCsv(string? value)
    {
        var text = value ?? string.Empty;
        if (text.Contains('"'))
            text = text.Replace("\"", "\"\"");

        return $"\"{text}\"";
    }

    private static string FormatUserShortName(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName))
            return "—";

        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
            return "—";
        if (parts.Length == 1)
            return parts[0];

        var surname = parts[0];
        var initials = string.Concat(parts.Skip(1).Select(part => $"{char.ToUpperInvariant(part[0])}."));
        return $"{surname} {initials}";
    }

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "—";
    }

    private static string FormatDuration(int seconds)
    {
        var duration = TimeSpan.FromSeconds(Math.Max(0, seconds));
        return $"{(int)duration.TotalHours:00}:{duration.Minutes:00}:{duration.Seconds:00}";
    }

    private static string GetStatusLabel(int status)
    {
        return (WorkStatus)status switch
        {
            WorkStatus.Completed => "Завершена",
            WorkStatus.Paused => "Пауза",
            WorkStatus.Working => "В работе",
            _ => "Неактивна"
        };
    }

    private static string GetStatusClass(int status)
    {
        return (WorkStatus)status switch
        {
            WorkStatus.Completed => "ok",
            WorkStatus.Paused => "warn",
            WorkStatus.Working => "info",
            _ => "neutral"
        };
    }
}
