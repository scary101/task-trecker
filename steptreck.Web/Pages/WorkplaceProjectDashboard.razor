@page "/workplace/projects/{ProjectId:int}/dashboard"
@using steptreck.Domain.DTOs.DashboardDTOs
@inject steptreck.Web.ViewModel.ProjectTeamDashboardViewModel DashboardVm
@inject NavigationManager Nav
@layout steptreck.Web.Layout.WorkplaceLayout

<PageTitle>Дашборд проекта — StepTreck</PageTitle>

<main class="page project-dashboard-page analytics-page">
    <section class="section">
        <ProjectSectionTabs ProjectId="ProjectId" Active="dashboard" />

        @if (_loading)
        {
            <div class="analytics-empty card">Загружаем дашборд проекта...</div>
        }
        else if (_dashboard is null)
        {
            <div class="analytics-empty card">Не удалось загрузить аналитику проекта.</div>
        }
        else
        {
            <section class="analytics-hero card">
                <div>
                    <div class="analytics-kicker">Project Health</div>
                    <h1>@_dashboard.ProjectName</h1>
                    <p>@(!string.IsNullOrWhiteSpace(_dashboard.ProjectDescription) ? _dashboard.ProjectDescription : "Описание проекта не задано.")</p>
                </div>
                <div class="score-orbit @ScoreClass(_dashboard.Health.DeliveryScore)">
                    <span>Delivery Score</span>
                    <strong>@_dashboard.Health.DeliveryScore</strong>
                </div>
            </section>

            <section class="analytics-kpis">
                <article class="analytics-kpi card">
                    <span>Deadline Pressure</span>
                    <strong>@_dashboard.Health.DeadlinePressure</strong>
                    <small>просрочки + близкие дедлайны + задачи без владельца</small>
                </article>
                <article class="analytics-kpi card">
                    <span>Баланс нагрузки</span>
                    <strong>@_dashboard.Health.WorkloadBalance%</strong>
                    <small>ровность распределения задач между командами</small>
                </article>
                <article class="analytics-kpi card">
                    <span>В срок</span>
                    <strong>@_dashboard.Health.OnTimeRate%</strong>
                    <small>закрытые против missed</small>
                </article>
                <article class="analytics-kpi card">
                    <span>Участники риска</span>
                    <strong>@_dashboard.Health.RiskMemberRate%</strong>
                    <small>trust ниже 50 или есть просрочки</small>
                </article>
            </section>

            <section class="analytics-grid">
                <article class="analytics-panel card">
                    <h2>Задачи</h2>
                    <div class="metric-list">
                        <div><span>Активные</span><strong>@_dashboard.Tasks.ActiveTasks</strong></div>
                        <div><span>Готово</span><strong>@_dashboard.Tasks.DoneTasks</strong></div>
                        <div><span>Просрочено</span><strong class="@ToneClass(_dashboard.Tasks.OverdueTasks)">@_dashboard.Tasks.OverdueTasks</strong></div>
                        <div><span>Сегодня</span><strong>@_dashboard.Tasks.DueTodayTasks</strong></div>
                        <div><span>Неделя</span><strong>@_dashboard.Tasks.DueThisWeekTasks</strong></div>
                        <div><span>Без ответственного</span><strong class="@ToneClass(_dashboard.Tasks.UnassignedTasks)">@_dashboard.Tasks.UnassignedTasks</strong></div>
                    </div>
                </article>

                <article class="analytics-panel card">
                    <h2>Работа</h2>
                    <div class="metric-list">
                        <div><span>Активные сессии</span><strong>@_dashboard.Workload.ActiveSessions</strong></div>
                        <div><span>В работе</span><strong>@_dashboard.Workload.WorkingSessions</strong></div>
                        <div><span>Пауза</span><strong>@_dashboard.Workload.PausedSessions</strong></div>
                        <div><span>Сегодня</span><strong>@FormatDuration(_dashboard.Workload.WorkedSecondsToday)</strong></div>
                        <div><span>7 дней</span><strong>@FormatDuration(_dashboard.Workload.WorkedSecondsLast7Days)</strong></div>
                    </div>
                </article>

                <article class="analytics-panel card insights-panel">
                    <h2>Что важно</h2>
                    <div class="insight-list">
                        @foreach (var insight in _dashboard.Insights)
                        {
                            <div class="insight-item">
                                <i class="bi bi-lightning-charge" aria-hidden="true"></i>
                                <span>@insight</span>
                            </div>
                        }
                    </div>
                </article>
            </section>

            <section class="analytics-section">
                <div class="analytics-section-head">
                    <h2>Команды проекта</h2>
                    <p>Сортировка выводит наверх команды с просрочками и высокой активной нагрузкой.</p>
                </div>
                <div class="analytics-table">
                    <div class="analytics-row head">
                        <span>Команда</span><span>Участники</span><span>Активные</span><span>Просрочено</span><span>Без ответственного</span><span>Доля нагрузки</span>
                    </div>
                    @foreach (var team in _dashboard.Teams)
                    {
                        <button class="analytics-row action" type="button" @onclick="() => OpenTeam(team.TeamId)">
                            <span>@team.TeamName</span>
                            <span>@team.MembersCount</span>
                            <span>@team.ActiveTasks</span>
                            <span class="@ToneClass(team.OverdueTasks)">@team.OverdueTasks</span>
                            <span class="@ToneClass(team.UnassignedTasks)">@team.UnassignedTasks</span>
                            <span>@team.LoadShare%</span>
                        </button>
                    }
                </div>
            </section>

            <section class="analytics-section">
                <div class="analytics-section-head">
                    <h2>Участники риска</h2>
                    <p>Люди, которым сейчас нужна поддержка, разгрузка или контроль дедлайнов.</p>
                </div>
                <div class="analytics-cards">
                    @foreach (var member in _dashboard.MemberRisks)
                    {
                        <article class="risk-card card">
                            <div>
                                <strong>@member.FullName</strong>
                                <span>@member.TeamName</span>
                            </div>
                            <div class="risk-meta">
                                <span>trust @member.Trust</span>
                                <span>@member.ActiveTasks задач</span>
                                <span class="@ToneClass(member.OverdueTasks)">@member.OverdueTasks проср.</span>
                            </div>
                        </article>
                    }
                </div>
            </section>
        }
    </section>
</main>

@code {
    [Parameter] public int ProjectId { get; set; }

    private ProjectDashboardDto? _dashboard;
    private bool _loading = true;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _dashboard = await DashboardVm.GetProjectAsync(ProjectId);
        _loading = false;
    }

    private void OpenTeam(int teamId) => Nav.NavigateTo($"/workplace/projects/{ProjectId}/teams/{teamId}/dashboard");
    private void GoToInfo() => Nav.NavigateTo($"/workplace/projects/{ProjectId}");
    private void GoToTeams() => Nav.NavigateTo($"/workplace/projects/{ProjectId}/teams");
    private void GoToMembers() => Nav.NavigateTo($"/workplace/projects/{ProjectId}/members");
    private void GoToFiles() => Nav.NavigateTo($"/workplace/projects/{ProjectId}/files");

    private static string ToneClass(int value) => value > 0 ? "tone-risk" : "tone-ok";
    private static string ScoreClass(decimal score) => score >= 75 ? "good" : score >= 55 ? "watch" : "risk";

    private static string FormatDuration(long seconds)
    {
        if (seconds <= 0) return "0ч";
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalHours >= 1 ? $"{(int)ts.TotalHours}ч {ts.Minutes}м" : $"{ts.Minutes}м";
    }
}
