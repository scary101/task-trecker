@page "/workplace/chats"
@page "/workplace/projects/{ProjectId:int}/teams/{TeamId:int}/chat"
@using steptreck.Domain.Constants
@using steptreck.Domain.DTOs.ChatDTOs
@using steptreck.Domain.DTOs.MemberDTOs
@using steptreck.Domain.DTOs.TeamDTOs
@using steptreck.Domain.DTOs.TeamDTOs.MemberDTOs
@using Microsoft.JSInterop
@inject steptreck.Web.ViewModel.ChatViewModel ChatVm
@inject steptreck.Web.Services.ChatClient ChatClient
@inject steptreck.Web.ViewModel.ProjectTeamsViewModel TeamsVm
@inject steptreck.Web.ViewModel.MembersVm MembersVm
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject steptreck.Web.Services.IUserRoleStore RoleStore
@layout steptreck.Web.Layout.WorkplaceLayout
@implements IAsyncDisposable

<PageTitle>Чаты команд — StepTreck</PageTitle>

<main class="page team-chat-page owner-chats-page">
    @if (ProjectId > 0 && TeamId > 0 && _roleReady && !_isOwner && !_isTeamLead && !_isEmployee)
    {
        <section class="section">
            <TeamSectionTabs ProjectId="ProjectId"
                             TeamId="TeamId"
                             Active="chat"
                             ShowWorkspaceLinks="@(!_isOwner)"
                             ShowTaskLinks="@(!_isOwner)" />
        </section>
    }

    <section class="owner-chat-shell">
        <aside class="chat-list-panel">
            <div class="chat-list-head">
                <div>
                    <h1>@(_isOwner ? "Чаты команд" : "Командный чат")</h1>
                    <span>@(_isOwner ? $"{_chats.Count} активных каналов" : "Рабочее общение команды")</span>
                </div>
                <button class="chat-refresh" type="button" @onclick="ReloadChatsAsync" disabled="@_loadingChats" aria-label="Обновить">
                    <i class="bi bi-arrow-clockwise" aria-hidden="true"></i>
                </button>
            </div>

            @if (_isOwner)
            {
                <label class="chat-search">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    <input type="search" placeholder="Поиск" @bind="_chatListQuery" @bind:event="oninput" />
                </label>
            }

            <div class="chat-list">
                @if (_loadingChats)
                {
                    <div class="chat-list-empty">Загружаем чаты...</div>
                }
                else if (FilteredChats.Count == 0)
                {
                    <div class="chat-list-empty">Чаты не найдены.</div>
                }
                else
                {
                    @foreach (var chat in FilteredChats)
                    {
                        <button class="chat-list-item @(chat.TeamId == _selectedTeamId ? "selected" : "")"
                                type="button"
                                @onclick="() => SelectChatAsync(chat.TeamId)">
                            <span class="chat-avatar">@GetInitials(chat.TeamName)</span>
                            <span class="chat-item-main">
                                <span class="chat-item-title">@chat.TeamName</span>
                                <span class="chat-item-preview">@TrimPreview(chat.LastMessageText)</span>
                            </span>
                            <span class="chat-item-side">
                                <span>@FormatShortTime(chat.LastMessageAt)</span>
                                @if (chat.UnreadCount > 0)
                                {
                                    <strong>@chat.UnreadCount</strong>
                                }
                            </span>
                        </button>
                    }
                }
            </div>
        </aside>

        <section class="chat-room-panel">
            @if (_selectedChat is null)
            {
                <div class="chat-room-empty">
                    <i class="bi bi-chat-square-text" aria-hidden="true"></i>
                    <h2>Выберите чат</h2>
                    <p>Слева отображаются доступные рабочие чаты команд.</p>
                </div>
            }
            else
            {
                <header class="chat-room-head">
                    <span class="chat-avatar large">@GetInitials(_selectedChat.TeamName)</span>
                    <div>
                        <h2>@_selectedChat.TeamName</h2>
                        <p>@_selectedChat.ProjectName</p>
                    </div>
                    <div class="chat-head-actions">
                        <button class="icon-btn ghost @(_searchOpen ? "active" : "")" type="button" aria-label="Поиск" @onclick="ToggleSearch">
                            <i class="bi bi-search" aria-hidden="true"></i>
                        </button>
                        <button class="open-team-btn" type="button" @onclick="OpenTeam">
                            <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
                            <span>Команда</span>
                        </button>
                    </div>
                </header>

                @if (!string.IsNullOrWhiteSpace(_alert))
                {
                    <div class="alert @(_alertKind)">@_alert</div>
                }

                @if (_searchOpen)
                {
                    <div class="chat-search-panel">
                        <label class="chat-search-field">
                            <i class="bi bi-search" aria-hidden="true"></i>
                            <input type="search"
                                   value="@_searchQuery"
                                   @oninput="OnSearchInput"
                                   placeholder="Поиск по сообщениям" />
                        </label>
                        <div class="chat-search-meta">@SearchCounterText</div>
                        <div class="chat-search-actions">
                            <button type="button" title="Предыдущее" @onclick="SearchPreviousAsync" disabled="@(!_searchMatches.Any())">↑</button>
                            <button type="button" title="Следующее" @onclick="SearchNextAsync" disabled="@(!_searchMatches.Any())">↓</button>
                            <button type="button" @onclick="LoadMoreForSearchAsync" disabled="@(!_hasMore || _loadingMore)">
                                @(_loadingMore ? "Ищем..." : "Глубже")
                            </button>
                            <button type="button" title="Закрыть поиск" @onclick="CloseSearch">×</button>
                        </div>
                    </div>
                }

                @if (PinnedMessage is not null)
                {
                    <div class="pinned-banner">
                        <button class="pinned-main" type="button" @onclick="() => ScrollToMessageAsync(PinnedMessage.Id)">
                            <span class="pinned-icon">📌</span>
                            <span>
                                <strong>Закрепленное сообщение</strong>
                                <span>@TrimPreview(PinnedMessage.Text)</span>
                            </span>
                        </button>
                        <button class="pinned-close" type="button" title="Открепить" @onclick="() => TogglePinAsync(PinnedMessage)">×</button>
                    </div>
                }

                <div class="chat-room-stream" @ref="_streamRef">
                    <div class="chat-stream-head">
                        <button class="chat-history-btn" type="button" @onclick="LoadMoreAsync" disabled="@(!_hasMore || _loadingMore || _loadingMessages)">
                            @(_loadingMore ? "Загружаем..." : _hasMore ? "Показать ещё" : "Больше сообщений нет")
                        </button>
                    </div>

                    @if (_loadingMessages)
                    {
                        <div class="chat-room-empty compact">Загружаем сообщения...</div>
                    }
                    else if (_messages.Count == 0)
                    {
                        <div class="chat-room-empty compact">Пока нет сообщений. Начните разговор первым.</div>
                    }
                    else
                    {
                        DateTime? currentDay = null;
                        @for (var i = 0; i < _messages.Count; i++)
                        {
                            var msg = _messages[i];
                            var isMine = IsMine(msg);
                            var showName = ShouldShowName(i);
                            var showTime = ShouldShowTime(i);
                            var grouped = IsGrouped(i);
                            var localDay = msg.CreatedAt.ToLocalTime().Date;

                            if (currentDay != localDay)
                            {
                                currentDay = localDay;
                                <div class="chat-date-separator">
                                    <span>@FormatDayLabel(localDay)</span>
                                </div>
                            }

                            <article class="message-row @(isMine ? "me" : "other") @RoleClass(msg.Role) @(grouped ? "grouped" : "") @(msg.Id == _highlightedMessageId ? "highlighted" : "") @(msg.Id == CurrentSearchMessageId ? "search-current" : "") @(IsSearchMatch(msg.Id) ? "search-match" : "")"
                                     data-message-id="@msg.Id"
                                     @key="msg.Id">
                                @if (!isMine)
                                {
                                    <div class="message-avatar @(showName ? "" : "hidden")">@GetInitials(msg.SenderName)</div>
                                }

                                <div class="message-stack">
                                    @if (showName && !isMine)
                                    {
                                        <div class="message-sender">@msg.SenderName</div>
                                    }

                                    <div class="message-bubble" data-copy-text="@msg.Text">
                                        <div class="message-tools">
                                            @if (msg.IsPinned)
                                            {
                                                <span class="message-pin" title="Закреплено">📌</span>
                                            }
                                            <button class="message-menu-btn" type="button" title="Действия" @onclick="() => ToggleMessageMenu(msg.Id)">⋯</button>
                                        </div>

                                        @if (msg.ReplyTo is not null || msg.ReplyToMessageId.HasValue)
                                        {
                                            <button class="reply-preview" type="button" @onclick="() => ScrollToMessageAsync(msg.ReplyToMessageId ?? msg.ReplyTo?.Id ?? 0)">
                                                <strong>@(msg.ReplyTo?.SenderName ?? "Сообщение")</strong>
                                                <span>@TrimPreview(msg.ReplyTo?.Text)</span>
                                            </button>
                                        }

                                        <div class="message-text">
                                            @foreach (var part in GetMessageTextParts(msg.Text))
                                            {
                                                if (part.MemberId.HasValue)
                                                {
                                                    <button type="button" class="mention-link" @onclick="() => OpenMemberProfile(part.MemberId.Value)">@part.Text</button>
                                                }
                                                else
                                                {
                                                    @part.Text
                                                }
                                            }
                                        </div>

                                        @if (msg.Reactions.Count > 0)
                                        {
                                            <div class="reaction-summary">
                                                @foreach (var reaction in msg.Reactions.Where(r => r.Count > 0))
                                                {
                                                    <button class="reaction-chip @(reaction.ReactedByMe ? "mine" : "")" type="button" @onclick="() => ToggleReactionAsync(msg, reaction.Emoji)">
                                                        <span>@reaction.Emoji</span>
                                                        <strong>@reaction.Count</strong>
                                                    </button>
                                                }
                                            </div>
                                        }

                                        @if (showTime)
                                        {
                                            <div class="message-time message-time--inside">@FormatTimestamp(msg.CreatedAt)</div>
                                        }

                                        @if (_openMessageMenuId == msg.Id)
                                        {
                                            <div class="message-actions-menu">
                                                <div class="reaction-palette" aria-label="Реакции">
                                                    @foreach (var emoji in QuickReactions)
                                                    {
                                                        <button class="reaction-option" type="button" @onclick="() => ToggleReactionAsync(msg, emoji)">@emoji</button>
                                                    }
                                                </div>
                                                <button type="button" @onclick="() => StartReply(msg)">Ответить</button>
                                                <button type="button" @onclick="() => CopyMessageAsync(msg.Text)">Копировать</button>
                                                <button type="button" @onclick="() => TogglePinAsync(msg)">@(msg.IsPinned ? "Открепить" : "Закрепить")</button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    }
                </div>

                <div class="chat-compose-wrap">
                    <div class="chat-compose">
                        @if (_visibleMentionSuggestions.Count > 0)
                        {
                            <div class="mention-panel">
                                @foreach (var suggestion in _visibleMentionSuggestions)
                                {
                                    <button type="button" class="mention-option" @onclick="() => ApplyMentionSuggestion(suggestion)">
                                        <span>@(suggestion.Username == "all" ? "@" : GetInitials(suggestion.Label))</span>
                                        <strong>@suggestion.Label</strong>
                                        <small>@suggestion.Subtitle</small>
                                    </button>
                                }
                            </div>
                        }

                        @if (_replyToMessage is not null)
                        {
                            <div class="compose-reply">
                                <div>
                                    <strong>Ответ: @_replyToMessage.SenderName</strong>
                                    <span>@TrimPreview(_replyToMessage.Text)</span>
                                </div>
                                <button type="button" title="Отменить ответ" @onclick="ClearReply">×</button>
                            </div>
                        }

                        <div class="compose-main">
                            <div class="compose-input">
                                <button class="emoji-btn" type="button" aria-label="Открыть панель эмодзи" aria-expanded="false" @ref="_emojiButtonEl">
                                    <i class="bi bi-emoji-smile" aria-hidden="true"></i>
                                </button>
                                <div class="emoji-panel" hidden @ref="_emojiPanelEl">
                                    <div class="emoji-panel-title">Смайлики</div>
                                    <div class="emoji-grid">
                                        @foreach (var emoji in EmojiPalette)
                                        {
                                            <button class="emoji-chip" type="button" data-emoji="@emoji" aria-label="Добавить @emoji">
                                                @emoji
                                            </button>
                                        }
                                    </div>
                                </div>
                                <textarea class="input"
                                          @bind="_messageText"
                                          @bind:event="oninput"
                                          @bind:after="AfterComposerInput"
                                          maxlength="@ChatConstants.MaxMessageTextLength"
                                          rows="1"
                                          placeholder="Напишите сообщение..."
                                          @ref="_composerEl">
                                </textarea>
                            </div>
                            <button class="send-btn" type="button" @onclick="SendAsync" disabled="@_sending" aria-label="Отправить сообщение">
                                <i class="bi bi-send-fill" aria-hidden="true"></i>
                            </button>
                        </div>
                        <div class="compose-actions">
                            <div class="compose-hint">Enter — отправить, Shift+Enter — новая строка</div>
                        </div>
                    </div>
                </div>
            }
        </section>
    </section>
</main>

@code {
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public int TeamId { get; set; }

    private readonly List<ChatListItemDto> _chats = new();
    private readonly List<ChatMessageDto> _messages = new();
    private readonly List<MentionSuggestion> _mentionSuggestions = new();
    private readonly List<MentionSuggestion> _visibleMentionSuggestions = new();
    private readonly Dictionary<string, int> _mentionMemberIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<long> _searchMatches = new();
    private bool _loadingChats = true;
    private bool _loadingMessages = true;
    private bool _loadingMore;
    private bool _sending;
    private bool _connected;
    private bool _hasMore = true;
    private bool _searchOpen;
    private bool _pendingScrollToBottom;
    private bool _composerInteropBound;
    private bool _roleReady;
    private bool _isOwner;
    private bool _isTeamLead;
    private bool _isEmployee;
    private int? _selectedTeamId;
    private int? _currentMemberId;
    private long? _beforeId;
    private long? _openMessageMenuId;
    private long? _highlightedMessageId;
    private int _searchIndex = -1;
    private string _chatListQuery = string.Empty;
    private string _messageText = string.Empty;
    private string _searchQuery = string.Empty;
    private string? _alert;
    private string _alertKind = "ok";
    private ChatMessageDto? _replyToMessage;
    private MentionQuery? _mentionQuery;
    private IDisposable? _subscription;
    private IDisposable? _reactionSubscription;
    private IDisposable? _pinSubscription;
    private DotNetObjectReference<WorkplaceTeamChat>? _composerHandle;
    private ElementReference _streamRef;
    private ElementReference _composerEl;
    private ElementReference _emojiButtonEl;
    private ElementReference _emojiPanelEl;

    private const int OwnerRoleId = 1;
    private const int TeamLeadRoleId = 3;
    private const int EmployeeRoleId = 4;
    private const int AdminRoleId = 5;
    private const int TimeGroupGapMinutes = 7;
    private static readonly string[] QuickReactions = ["🔥", "👍", "👎", "🤡"];
    private static readonly string[] EmojiPalette =
    [
        "😀", "😁", "😂", "🤣", "😊", "😍", "😘", "😎", "🤔", "😴",
        "🙌", "👏", "👍", "👎", "👊", "✌️", "🙏", "🔥", "💯", "✅",
        "❌", "⚡", "🎉", "🚀", "💡", "📌", "📎", "📅", "💬", "📢",
        "❤️", "🧡", "💛", "💚", "💙", "💜", "🤝", "👀", "😅", "🤯"
    ];

    private ChatListItemDto? _selectedChat => _chats.FirstOrDefault(x => x.TeamId == _selectedTeamId);

    private List<ChatListItemDto> FilteredChats => _chats
        .Where(c => string.IsNullOrWhiteSpace(_chatListQuery) ||
                    c.TeamName.Contains(_chatListQuery, StringComparison.OrdinalIgnoreCase) ||
                    c.ProjectName.Contains(_chatListQuery, StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(c => c.LastMessageAt ?? DateTime.MinValue)
        .ToList();

    private ChatMessageDto? PinnedMessage
        => _messages.LastOrDefault(message => message.IsPinned);

    private long? CurrentSearchMessageId
        => _searchIndex >= 0 && _searchIndex < _searchMatches.Count
            ? _searchMatches[_searchIndex]
            : null;

    private string SearchCounterText
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_searchQuery))
                return "Введите запрос";
            if (_searchMatches.Count == 0)
                return _hasMore ? "В загруженных сообщениях нет" : "Ничего не найдено";
            return $"{_searchIndex + 1} из {_searchMatches.Count}";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        _roleReady = false;
        var roleId = await RoleStore.GetRoleIdAsync();
        if (roleId == AdminRoleId)
        {
            Nav.NavigateTo("/workplace/metrics", forceLoad: true);
            return;
        }

        _isOwner = roleId == OwnerRoleId;
        _isTeamLead = roleId == TeamLeadRoleId;
        _isEmployee = roleId == EmployeeRoleId;
        _roleReady = true;
        var profile = await MembersVm.GetMyProfileAsync();
        _currentMemberId = profile?.Id;

        await EnsureConnectedAsync();
        await LoadChatsAsync(preferredTeamId: TeamId > 0 ? TeamId : null);
    }

    private async Task ReloadChatsAsync()
        => await LoadChatsAsync(_selectedTeamId);

    private async Task LoadChatsAsync(int? preferredTeamId = null)
    {
        _loadingChats = true;
        var chats = await ChatVm.GetChatsAsync();

        if (!_isOwner)
        {
            if (preferredTeamId.HasValue)
                chats = chats.Where(x => x.TeamId == preferredTeamId.Value).ToList();
            else if (chats.Count > 1)
                chats = chats.Take(1).ToList();

            if (chats.Count == 0 && preferredTeamId.HasValue)
            {
                var team = await TeamsVm.GetTeamAsync(preferredTeamId.Value);
                if (team is not null)
                {
                    chats.Add(new ChatListItemDto
                    {
                        TeamId = team.Id,
                        ProjectId = team.ProjectId,
                        TeamName = team.Name,
                        ProjectName = $"Проект #{team.ProjectId}"
                    });
                }
            }
        }

        _chats.Clear();
        _chats.AddRange(chats);
        _loadingChats = false;

        var nextTeamId = preferredTeamId.HasValue && _chats.Any(x => x.TeamId == preferredTeamId.Value)
            ? preferredTeamId.Value
            : _chats.FirstOrDefault()?.TeamId;

        if (nextTeamId.HasValue)
            await SelectChatAsync(nextTeamId.Value);
        else
            _loadingMessages = false;
    }

    private async Task SelectChatAsync(int teamId)
    {
        if (_selectedTeamId == teamId && !_loadingMessages && _messages.Count > 0)
            return;

        _selectedTeamId = teamId;
        _loadingMessages = true;
        _composerInteropBound = false;
        _messages.Clear();
        _mentionSuggestions.Clear();
        _visibleMentionSuggestions.Clear();
        _mentionMemberIds.Clear();
        _replyToMessage = null;
        _mentionQuery = null;
        _openMessageMenuId = null;
        _searchMatches.Clear();
        _searchIndex = -1;
        _beforeId = null;
        _hasMore = true;
        _alert = null;

        var selected = _selectedChat;
        if (selected is not null)
        {
            TeamId = selected.TeamId;
            ProjectId = selected.ProjectId;
        }

        await LoadMoreAsync();
        await LoadMentionsAsync(teamId);
        _loadingMessages = false;
        RequestScrollToBottom();
    }

    private async Task LoadMentionsAsync(int teamId)
    {
        var usernames = await ChatVm.GetTeamUsernamesAsync(teamId);
        var members = new List<TeamMemberDto>();
        try
        {
            members = await TeamsVm.GetTeamMembersAsync(teamId);
        }
        catch
        {
        }

        var memberNames = members.ToDictionary(member => member.MemberId, member => member.FullName);
        foreach (var item in usernames.Where(item => !string.IsNullOrWhiteSpace(item.Username)))
        {
            var username = item.Username.Trim().TrimStart('@');
            var label = memberNames.TryGetValue(item.MemberId, out var fullName) && !string.IsNullOrWhiteSpace(fullName)
                ? fullName
                : $"@{username}";
            _mentionSuggestions.Add(new MentionSuggestion(username, label, $"@{username}"));
            _mentionMemberIds[username] = item.MemberId;
        }
    }

    private async Task EnsureConnectedAsync()
    {
        if (_connected)
            return;

        try
        {
            await ChatClient.StartAsync();
            _subscription?.Dispose();
            _reactionSubscription?.Dispose();
            _pinSubscription?.Dispose();

            _subscription = ChatClient.OnNewMessage(msg =>
            {
                _ = InvokeAsync(async () =>
                {
                    var chat = _chats.FirstOrDefault(x => x.TeamId == msg.TeamId);
                    if (chat is not null)
                    {
                        chat.LastMessageText = msg.Text;
                        chat.LastMessageAt = msg.CreatedAt;
                    }

                    if (_selectedTeamId != msg.TeamId || _messages.Any(m => m.Id == msg.Id))
                    {
                        StateHasChanged();
                        return;
                    }

                    var nearBottom = true;
                    try
                    {
                        nearBottom = await JS.InvokeAsync<bool>("steptreckChat.isNearBottom", _streamRef);
                    }
                    catch
                    {
                    }

                    _messages.Add(msg);
                    _messages.Sort((a, b) => a.Id.CompareTo(b.Id));
                    RefreshSearchMatches(keepCurrent: true);
                    if (nearBottom)
                        RequestScrollToBottom();
                    StateHasChanged();
                });
            });

            _reactionSubscription = ChatClient.OnReactionChanged(dto =>
            {
                _ = InvokeAsync(() =>
                {
                    if (_selectedTeamId != dto.TeamId)
                        return;
                    ApplyReactionChanged(dto);
                    StateHasChanged();
                });
            });

            _pinSubscription = ChatClient.OnPinChanged(dto =>
            {
                _ = InvokeAsync(() =>
                {
                    if (_selectedTeamId != dto.TeamId)
                        return;
                    ApplyPinChanged(dto);
                    StateHasChanged();
                });
            });

            _connected = true;
        }
        catch (Exception ex)
        {
            _alertKind = "err";
            _alert = $"SignalR connect failed: {ex.GetType().Name}: {ex.Message}";
        }
    }

    private async Task LoadMoreAsync()
    {
        if (_loadingMore || !_selectedTeamId.HasValue)
            return;

        _loadingMore = true;
        var items = await ChatVm.GetMessagesAsync(_selectedTeamId.Value, _beforeId, 50);
        items.Sort((a, b) => a.Id.CompareTo(b.Id));

        if (items.Count == 0)
        {
            _hasMore = false;
            _loadingMore = false;
            return;
        }

        _messages.InsertRange(0, items);
        _beforeId = _messages.First().Id;
        if (items.Count < 50)
            _hasMore = false;

        _loadingMore = false;
        RefreshSearchMatches(keepCurrent: true);
    }

    private async Task SendAsync()
    {
        if (_sending || !_selectedTeamId.HasValue)
            return;

        var text = _messageText.Trim();
        if (string.IsNullOrWhiteSpace(text))
            return;

        if (text.Length > ChatConstants.MaxMessageTextLength)
        {
            _alertKind = "err";
            _alert = ChatMessageTooLongText();
            await InvokeAsync(StateHasChanged);
            return;
        }

        _sending = true;
        _alert = null;
        try
        {
            await EnsureConnectedAsync();
            await ChatClient.SendMessage(_selectedTeamId.Value, text, _replyToMessage?.Id);

            _messageText = string.Empty;
            _replyToMessage = null;
            _mentionQuery = null;
            _visibleMentionSuggestions.Clear();
            await JS.InvokeVoidAsync("steptreckChat.clearComposer", _composerEl);
            RequestScrollToBottom();
        }
        catch (Exception ex)
        {
            _alertKind = "err";
            _alert = ResolveSendErrorMessage(ex);
        }
        finally
        {
            _sending = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string ResolveSendErrorMessage(Exception ex)
    {
        var message = ex.Message ?? string.Empty;

        if (IsChatMessageTooLongError(message))
            return ChatMessageTooLongText();

        return "Не удалось отправить сообщение. Попробуйте ещё раз.";
    }

    private static bool IsChatMessageTooLongError(string message)
        => message.Contains("Сообщение слишком длинное", StringComparison.OrdinalIgnoreCase) ||
           message.Contains("Connection closed with an error", StringComparison.OrdinalIgnoreCase) ||
           message.Contains("server closed the connection", StringComparison.OrdinalIgnoreCase) ||
           message.Contains("Maximum message size", StringComparison.OrdinalIgnoreCase);

    private static string ChatMessageTooLongText()
        => $"Сообщение слишком длинное. Максимум {ChatConstants.MaxMessageTextLength} символов.";

