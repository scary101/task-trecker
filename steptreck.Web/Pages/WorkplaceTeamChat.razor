    private bool ShouldShowName(int index)
    {
        if (index <= 0) return true;
        var current = _messages[index];
        var prev = _messages[index - 1];
        if (current.SenderMemberId != prev.SenderMemberId) return true;
        return GetGapMinutes(prev.CreatedAt, current.CreatedAt) > TimeGroupGapMinutes;
    }

    private bool ShouldShowTime(int index)
    {
        if (index <= 0) return true;
        var current = _messages[index];
        var prev = _messages[index - 1];
        if (current.SenderMemberId != prev.SenderMemberId) return true;
        return GetGapMinutes(prev.CreatedAt, current.CreatedAt) > TimeGroupGapMinutes;
    }

    private bool IsGrouped(int index)
    {
        if (index <= 0) return false;
        var current = _messages[index];
        var prev = _messages[index - 1];
        return current.SenderMemberId == prev.SenderMemberId &&
               GetGapMinutes(prev.CreatedAt, current.CreatedAt) <= TimeGroupGapMinutes;
    }

    private static int GetGapMinutes(DateTime earlier, DateTime later)
        => (int)Math.Abs((later - earlier).TotalMinutes);

    private static string FormatTimestamp(DateTime value)
    {
        var local = value.ToLocalTime();
        var today = DateTime.Now.Date;
        if (local.Date == today)
            return $"Сегодня, {local:HH:mm}";
        return local.ToString("dd.MM, HH:mm");
    }

    private static string FormatShortTime(DateTime? value)
    {
        if (!value.HasValue)
            return "";

        var local = value.Value.ToLocalTime();
        return local.Date == DateTime.Now.Date ? local.ToString("HH:mm") : local.ToString("dd.MM");
    }

    private static string GetInitials(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "?";

        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
            return parts[0][0].ToString().ToUpperInvariant();

        return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }

    private void UpdateMentionSuggestions()
    {
        var query = ExtractMentionQuery(_messageText);
        if (query is null)
        {
            _mentionQuery = null;
            _visibleMentionSuggestions.Clear();
            return;
        }

        _mentionQuery = query;
        _visibleMentionSuggestions.Clear();
        if (string.IsNullOrWhiteSpace(query.Value.Query) || "all".StartsWith(query.Value.Query, StringComparison.OrdinalIgnoreCase))
            _visibleMentionSuggestions.Add(new MentionSuggestion("all", "@all", "Вся команда"));

        foreach (var item in _mentionSuggestions
            .Where(item => string.IsNullOrWhiteSpace(query.Value.Query) || item.Username.StartsWith(query.Value.Query, StringComparison.OrdinalIgnoreCase))
            .Take(6 - _visibleMentionSuggestions.Count))
        {
            _visibleMentionSuggestions.Add(item);
        }
    }

    private void ApplyMentionSuggestion(MentionSuggestion suggestion)
    {
        if (_mentionQuery is not { } query)
            return;

        var insert = $"@{suggestion.Username} ";
        _messageText = string.Concat(
            _messageText.AsSpan(0, query.Start),
            insert,
            _messageText.AsSpan(query.End));
        _visibleMentionSuggestions.Clear();
        _mentionQuery = null;
        _ = JS.InvokeVoidAsync("steptreckChat.setComposerValue", _composerEl, _messageText);
    }

    private IEnumerable<MessageTextPart> GetMessageTextParts(string text)
    {
        if (string.IsNullOrEmpty(text))
            yield break;

        var index = 0;
        while (index < text.Length)
        {
            var start = text.IndexOf('@', index);
            if (start < 0)
            {
                yield return new MessageTextPart(text[index..], null);
                yield break;
            }

            if (start > index)
                yield return new MessageTextPart(text[index..start], null);

            var end = start + 1;
            while (end < text.Length && IsMentionChar(text[end]))
                end++;

            if (end == start + 1)
            {
                yield return new MessageTextPart("@", null);
                index = end;
                continue;
            }

            var username = text[(start + 1)..end];
            if (_mentionMemberIds.TryGetValue(username, out var memberId))
                yield return new MessageTextPart(text[start..end], memberId);
            else
                yield return new MessageTextPart(text[start..end], null);

            index = end;
        }
    }

    private static bool IsMentionChar(char value)
        => char.IsLetterOrDigit(value) || value is '_' or '-' or '.';

    private void OpenMemberProfile(int memberId)
        => Nav.NavigateTo($"/workplace/members/{memberId}");

    private static MentionQuery? ExtractMentionQuery(string text)
    {
        if (string.IsNullOrEmpty(text))
            return null;

        var caret = text.Length;
        var start = text.LastIndexOf('@', Math.Max(0, caret - 1));
        if (start < 0)
            return null;

        if (start > 0 && !char.IsWhiteSpace(text[start - 1]))
            return null;

        var value = text[(start + 1)..caret];
        if (value.Any(char.IsWhiteSpace) || value.Length > 32)
            return null;

        return new MentionQuery(start, caret, value);
    }

    private static string TrimPreview(string? text)
    {
        var value = string.IsNullOrWhiteSpace(text) ? "Нет сообщений" : text.Trim().ReplaceLineEndings(" ");
        return value.Length <= 90 ? value : $"{value[..90]}...";
    }

    private static string FormatDayLabel(DateTime localDay)
    {
        var today = DateTime.Now.Date;
        if (localDay == today)
            return "Сегодня";
        if (localDay == today.AddDays(-1))
            return "Вчера";

        var label = $"{MonthName(localDay.Month)} {localDay.Day}";
        if (localDay.Year != today.Year)
            label += $" {localDay.Year}";

        return label;
    }

    private static string MonthName(int month) => month switch
    {
        1 => "Январь",
        2 => "Февраль",
        3 => "Март",
        4 => "Апрель",
        5 => "Май",
        6 => "Июнь",
        7 => "Июль",
        8 => "Август",
        9 => "Сентябрь",
        10 => "Октябрь",
        11 => "Ноябрь",
        12 => "Декабрь",
        _ => ""
    };

