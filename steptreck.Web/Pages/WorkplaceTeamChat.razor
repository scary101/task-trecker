    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _composerHandle ??= DotNetObjectReference.Create(this);

        if (!_loadingMessages && _selectedChat is not null && !_composerInteropBound)
        {
            try
            {
                await JS.InvokeVoidAsync("steptreckChat.autosize", _composerEl);
                await JS.InvokeVoidAsync("steptreckChat.bindComposer", _composerEl, _composerHandle);
                await JS.InvokeVoidAsync("steptreckChat.bindEmojiPicker", _emojiButtonEl, _emojiPanelEl, _composerEl);
                await JS.InvokeVoidAsync("steptreckChat.bindMessageCopy", _streamRef);
                _composerInteropBound = true;
            }
            catch
            {
            }
        }

        if (_pendingScrollToBottom)
        {
            _pendingScrollToBottom = false;
            await ScrollToBottomAsync();
        }
    }

    private void RequestScrollToBottom()
        => _pendingScrollToBottom = true;

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("steptreckChat.scrollToBottom", _streamRef);
        }
        catch
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        _subscription?.Dispose();
        _reactionSubscription?.Dispose();
        _pinSubscription?.Dispose();
        _composerHandle?.Dispose();

        if (_connected)
            await ChatClient.DisposeAsync();
    }

