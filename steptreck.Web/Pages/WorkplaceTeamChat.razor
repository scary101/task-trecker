    private async Task ToggleReactionAsync(ChatMessageDto message, string emoji)
    {
        _openMessageMenuId = null;
        var previous = message.Reactions.Select(CloneReaction).ToList();
        message.Reactions = ToggleReactionState(message.Reactions, emoji);

        try
        {
            await EnsureConnectedAsync();
            await ChatClient.ToggleReaction(message.Id, emoji);
        }
        catch (Exception ex)
        {
            message.Reactions = previous;
            _alertKind = "err";
            _alert = $"Не удалось поставить реакцию: {ex.Message}";
        }
    }

    private async Task TogglePinAsync(ChatMessageDto message)
    {
        _openMessageMenuId = null;
        var previous = _messages.Select(CloneMessage).ToList();
        ApplyLocalPin(message.Id, !message.IsPinned);

        try
        {
            await EnsureConnectedAsync();
            await ChatClient.TogglePinMessage(message.Id);
        }
        catch (Exception ex)
        {
            _messages.Clear();
            _messages.AddRange(previous);
            _alertKind = "err";
            _alert = $"Не удалось изменить закрепление: {ex.Message}";
        }
    }

    private void ApplyReactionChanged(ChatReactionChangedDto dto)
    {
        var message = _messages.FirstOrDefault(item => item.Id == dto.MessageId);
        if (message is null)
            return;

        var reaction = message.Reactions.FirstOrDefault(item => item.Emoji == dto.Emoji);
        if (dto.Count <= 0)
        {
            if (reaction is not null)
                message.Reactions.Remove(reaction);
            return;
        }

        var isMine = _currentMemberId.HasValue && dto.MemberId == _currentMemberId.Value
            ? dto.IsAdded
            : reaction?.ReactedByMe == true;

        if (reaction is null)
        {
            message.Reactions.Add(new ChatReactionDto
            {
                Emoji = dto.Emoji,
                Count = dto.Count,
                ReactedByMe = isMine
            });
        }
        else
        {
            reaction.Count = dto.Count;
            reaction.ReactedByMe = isMine;
        }
    }

    private void ApplyPinChanged(ChatPinChangedDto dto)
        => ApplyLocalPin(dto.MessageId, dto.IsPinned, dto.PinnedAt, dto.PinnedByMemberId);

    private void ApplyLocalPin(long messageId, bool isPinned, DateTime? pinnedAt = null, int? pinnedByMemberId = null)
    {
        foreach (var item in _messages)
        {
            if (isPinned && item.Id != messageId && item.IsPinned)
            {
                item.IsPinned = false;
                item.PinnedAt = null;
                item.PinnedByMemberId = null;
                continue;
            }

            if (item.Id == messageId)
            {
                item.IsPinned = isPinned;
                item.PinnedAt = isPinned ? pinnedAt ?? DateTime.UtcNow : null;
                item.PinnedByMemberId = isPinned ? pinnedByMemberId ?? _currentMemberId : null;
            }
        }
    }

    private List<ChatReactionDto> ToggleReactionState(List<ChatReactionDto> reactions, string emoji)
    {
        var updated = reactions.Select(CloneReaction).ToList();
        var reaction = updated.FirstOrDefault(item => item.Emoji == emoji);
        if (reaction is null)
        {
            updated.Add(new ChatReactionDto { Emoji = emoji, Count = 1, ReactedByMe = true });
        }
        else if (reaction.ReactedByMe)
        {
            reaction.Count--;
            reaction.ReactedByMe = false;
            if (reaction.Count <= 0)
                updated.Remove(reaction);
        }
        else
        {
            reaction.Count++;
            reaction.ReactedByMe = true;
        }

        return updated
            .OrderBy(item => Array.IndexOf(QuickReactions, item.Emoji) < 0 ? int.MaxValue : Array.IndexOf(QuickReactions, item.Emoji))
            .ThenBy(item => item.Emoji)
            .ToList();
    }

    private static ChatReactionDto CloneReaction(ChatReactionDto reaction)
        => new()
        {
            Emoji = reaction.Emoji,
            Count = reaction.Count,
            ReactedByMe = reaction.ReactedByMe
        };

    private static ChatMessageDto CloneMessage(ChatMessageDto message)
        => new()
        {
            Id = message.Id,
            TeamId = message.TeamId,
            SenderMemberId = message.SenderMemberId,
            SenderName = message.SenderName,
            Text = message.Text,
            Role = message.Role,
            CreatedAt = message.CreatedAt,
            IsPinned = message.IsPinned,
            PinnedAt = message.PinnedAt,
            PinnedByMemberId = message.PinnedByMemberId,
            ReplyToMessageId = message.ReplyToMessageId,
            ReplyTo = message.ReplyTo,
            Reactions = message.Reactions.Select(CloneReaction).ToList()
        };

    private async Task ScrollToMessageAsync(long messageId)
    {
        if (messageId <= 0)
            return;

        while (!_messages.Any(item => item.Id == messageId) && _hasMore && !_loadingMore)
            await LoadMoreAsync();

        await JS.InvokeVoidAsync("steptreckChat.scrollToMessage", _streamRef, messageId);
        _highlightedMessageId = messageId;
        StateHasChanged();
        _ = Task.Run(async () =>
        {
            await Task.Delay(1600);
            await InvokeAsync(() =>
            {
                if (_highlightedMessageId == messageId)
                {
                    _highlightedMessageId = null;
                    StateHasChanged();
                }
            });
        });
    }

    private bool IsMine(ChatMessageDto msg)
        => _currentMemberId.HasValue && msg.SenderMemberId == _currentMemberId.Value;

