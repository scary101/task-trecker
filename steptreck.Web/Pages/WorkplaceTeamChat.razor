    private void ToggleSearch()
    {
        _searchOpen = !_searchOpen;
        if (_searchOpen)
        {
            RefreshSearchMatches(keepCurrent: true);
            _openMessageMenuId = null;
            return;
        }

        CloseSearch();
    }

    private void CloseSearch()
    {
        _searchOpen = false;
        _searchQuery = string.Empty;
        _searchMatches.Clear();
        _searchIndex = -1;
    }

    private async Task OnSearchInput(ChangeEventArgs args)
    {
        _searchQuery = args.Value?.ToString() ?? string.Empty;
        RefreshSearchMatches(keepCurrent: false);
        if (_searchMatches.Count > 0)
            await ScrollToCurrentSearchAsync();
    }

    private async Task SearchNextAsync()
    {
        if (_searchMatches.Count == 0)
            return;
        _searchIndex = (_searchIndex + 1) % _searchMatches.Count;
        await ScrollToCurrentSearchAsync();
    }

    private async Task SearchPreviousAsync()
    {
        if (_searchMatches.Count == 0)
            return;
        _searchIndex = _searchIndex <= 0 ? _searchMatches.Count - 1 : _searchIndex - 1;
        await ScrollToCurrentSearchAsync();
    }

    private async Task LoadMoreForSearchAsync()
    {
        await LoadMoreAsync();
        RefreshSearchMatches(keepCurrent: true);
        if (_searchMatches.Count > 0)
            await ScrollToCurrentSearchAsync();
    }

    private async Task ScrollToCurrentSearchAsync()
    {
        if (CurrentSearchMessageId is { } messageId)
            await ScrollToMessageAsync(messageId);
    }

    private void RefreshSearchMatches(bool keepCurrent)
    {
        var current = keepCurrent ? CurrentSearchMessageId : null;
        _searchMatches.Clear();
        var query = _searchQuery.Trim();

        if (query.Length < 2)
        {
            _searchIndex = -1;
            return;
        }

        _searchMatches.AddRange(_messages
            .Where(message =>
                message.Text.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                message.SenderName.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                (message.ReplyTo?.Text?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false))
            .Select(message => message.Id));

        if (_searchMatches.Count == 0)
        {
            _searchIndex = -1;
            return;
        }

        var currentIndex = current.HasValue ? _searchMatches.IndexOf(current.Value) : -1;
        _searchIndex = currentIndex >= 0 ? currentIndex : _searchMatches.Count - 1;
    }

    private bool IsSearchMatch(long messageId)
        => _searchMatches.Contains(messageId);

